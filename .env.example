# ─── NovaWallet environment (example) ─────────────────────────────────────────
# Copy to .env and fill. NEVER commit real values. NEVER put key material here.

# Telegram
TELEGRAM_BOT_TOKEN=          # used ONLY server-side to verify initData; never sent to client
TELEGRAM_BOT_USERNAME=
INITDATA_MAX_AGE_SECONDS=86400   # freshness window for initData

# Backend
API_PORT=8787
NODE_ENV=development
DATABASE_URL=postgres://nova:nova@localhost:5432/nova
REDIS_URL=redis://localhost:6379

# RPC providers (server-side; abstracted, with failover)
TON_RPC_URL=
EVM_RPC_URL=                 # e.g. your Ethereum/Base RPC endpoint
EVM_CHAIN_ID=8453            # Base as the Phase-1 EVM chain (example)

# Price / data / risk providers
PRICE_API_URL=
PRICE_API_KEY=

# Frontend (Vite) — only PUBLIC values; prefixed VITE_
VITE_API_BASE_URL=http://localhost:8787
VITE_DEFAULT_EVM_CHAIN_ID=1

# Client RPC endpoints used to broadcast signed transactions (public values only).
# Without these, the wallet still validates, builds the review, and assesses risk,
# but the Send screen reports "network not connected" instead of broadcasting.
VITE_EVM_RPC_URL=
VITE_ARBITRUM_RPC_URL=
VITE_OPTIMISM_RPC_URL=
VITE_BASE_RPC_URL=
VITE_BSC_RPC_URL=
VITE_POLYGON_RPC_URL=
VITE_AVALANCHE_RPC_URL=
VITE_TON_RPC_URL=
VITE_SOLANA_RPC_URL=
VITE_BITCOIN_API_URL=https://mempool.space/api
